---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const PHONE = '(805) 341-4121';
const PHONE_LINK = 'tel:+18053414121';
const EMAIL = 'alohawindowbros@gmail.com';
const CALENDLY = 'https://calendly.com/alohawindowbros-r6nn/30min?hide_gdpr_banner=1';

const reviews = [
  { text: '"The Aloha Window Bros did a great job on our windows. It was easy to schedule and they were on time. Pricing is excellent!"', name: 'Mark S.', color: '#2563eb' },
  { text: '"Nobody likes cleaning windows, but these guys do. They are kind, professional and efficient."', name: 'Kathrine E.', color: '#e74c3c' },
  { text: '"They were very professional. Windows look awesome! 10 times better than last year."', name: 'Janelle R.', color: '#10b981' },
  { text: '"We are repeat customers. Professional, friendly & do a great job!"', name: 'Sheri M.', color: '#f59e0b' },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Aloha Window Bros",
  "description": "Professional window cleaning services in Ventura County and Santa Barbara County",
  "url": "https://alohawindowbros.com",
  "telephone": "+18053414121",
  "email": EMAIL,
  "logo": "https://alohawindowbros.com/img/logo.PNG",
  "image": "https://alohawindowbros.com/img/logo.PNG",
  "address": { "@type": "PostalAddress", "streetAddress": "138 Colt Lane", "addressLocality": "Thousand Oaks", "addressRegion": "CA", "postalCode": "91362" },
  "areaServed": ["Thousand Oaks", "Westlake Village", "Agoura Hills", "Newbury Park", "Ventura County", "Santa Barbara County"],
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "50" },
  "priceRange": "$150-$400"
};
---
<Base
  title="Aloha Window Bros - Window Cleaning Ventura County & Santa Barbara"
  description="Professional window cleaning in Ventura County and Santa Barbara. Fully insured, locally owned, 5-star rated. Free quotes — call (805) 341-4121."
  jsonLd={jsonLd}
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg-wrap">
      <img src="/img/wave_no_surfer.png" alt="" class="hero-bg-img" />
      <div class="hero-bg-overlay"></div>
    </div>
    <div class="hero-inner">
      <div class="hero-left">
        <a href="https://www.google.com/search?q=aloha+window+bros+reviews" target="_blank" rel="noopener noreferrer" class="hero-proof">
          <span class="hero-proof-stars">★★★★★</span>
          <span>Reviews (50+)</span>
        </a>
        <h1>Crystal Clear Windows,<br /><em>Island Hospitality</em></h1>
        <p class="hero-text">Two brothers bringing the spirit of aloha to Ventura & Santa Barbara County. We professionally clean your windows, screens, frames, and sills — leaving your home shining.</p>
        <div class="hero-badges">
          <span class="hero-badge">Fully Insured</span>
          <span class="hero-badge">Locally Owned</span>
          <span class="hero-badge">5.0 Rating</span>
        </div>
        <div class="hero-ctas">
          <a href={CALENDLY} class="hero-cta-primary" target="_blank" rel="noopener noreferrer">Get Your Free Quote</a>
          <a href={PHONE_LINK} class="hero-cta-phone">Or call {PHONE}</a>
        </div>
        <p class="hero-microcopy">Free on-site estimate · No obligation · Usually within 24 hrs</p>
      </div>
      <div class="hero-right">
        <div class="booking-widget">
          <div class="booking-header">
            <h3>Schedule in 30 Seconds</h3>
            <p class="subtitle">Pick your area — we'll come to you</p>
          </div>
          <a href={CALENDLY} class="btn-book btn-sb" target="_blank" rel="noopener noreferrer">Santa Barbara County</a>
          <a href={CALENDLY} class="btn-book btn-to" target="_blank" rel="noopener noreferrer">Ventura County / Thousand Oaks</a>
          <div class="booking-divider"><span>or call directly</span></div>
          <a href={PHONE_LINK} class="btn-book btn-call">{PHONE}</a>
          <div class="booking-proof">
            <img src="/img/nextdoorlogo_2.webp" alt="NextDoor" />
            <span>"Very efficient and professional. Definitely recommend." — Vanessa</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="mobile-cta-bar">
    <a href={PHONE_LINK} class="mobile-cta-call">Call Now</a>
    <a href={CALENDLY} class="mobile-cta-book" target="_blank" rel="noopener noreferrer">Free Quote</a>
  </div>

  <!-- Stats -->
  <section class="stats-bar">
    <div class="stat"><span class="stat-num">500+</span><span class="stat-label">Clients</span></div>
    <div class="stat"><span class="stat-num">50+</span><span class="stat-label">5-Star Reviews</span></div>
    <div class="stat"><span class="stat-num">100%</span><span class="stat-label">Satisfaction</span></div>
    <div class="stat"><span class="stat-num">24hr</span><span class="stat-label">Response Time</span></div>
  </section>

  <!-- Wave: Stats → How It Works -->
  <div class="wave-divider wave-divider-dark">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="wg1" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#1a1a2e"/>
          <stop offset="40%" stop-color="#1e2854"/>
          <stop offset="100%" stop-color="#2d1b69"/>
        </linearGradient>
      </defs>
      <path d="M0,0 L0,40 C240,75 480,20 720,45 C960,70 1200,15 1440,35 L1440,0 Z" fill="url(#wg1)"/>
      <path d="M0,0 L0,25 C300,55 600,5 900,30 C1100,48 1300,20 1440,28 L1440,0 Z" fill="url(#wg1)" opacity="0.4"/>
    </svg>
  </div>

  <!-- How It Works -->
  <section class="how-section">
    <h2>How It Works</h2>
    <p class="how-subtitle">Crystal clear windows in 3 easy steps</p>
    <div class="how-grid">
      <div class="how-step">
        <div class="how-step-num">1</div>
        <div class="how-step-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h3>Book Your Free Quote</h3>
        <p>Schedule online in 30 seconds or call us. We'll drive out to assess your property — no obligation. Then, we find a day that works best for you.</p>
      </div>
      <div class="how-step-arrow" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </div>
      <div class="how-step">
        <div class="how-step-num">2</div>
        <div class="how-step-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3>We Do the Work</h3>
        <p>Our team arrives on time with professional-grade tools. Windows, screens, frames, and sills — all spotless.</p>
      </div>
      <div class="how-step-arrow" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </div>
      <div class="how-step">
        <div class="how-step-num">3</div>
        <div class="how-step-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3>You Love the Results</h3>
        <p>We walk the property with you before we leave. Not happy? We redo it on the spot — 100% guaranteed.</p>
      </div>
    </div>
    <div class="how-cta">
      <a href={CALENDLY} class="hero-cta-primary" target="_blank" rel="noopener noreferrer">Get Your Free Quote</a>
      <span class="how-cta-sub">No obligation · Usually within 24 hrs</span>
    </div>
  </section>

  <!-- Reviews -->
  <section id="reviews" class="reviews-section">
    <h2>What Our Customers Say</h2>
    <p class="reviews-subtitle">Real reviews from real customers on NextDoor</p>
    <div class="reviews-grid">
      {reviews.map((r) => (
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <p class="review-text">{r.text}</p>
          <div class="review-author">
            <div class="author-avatar" style={`background: ${r.color}`}>{r.name[0]}</div>
            <div>
              <div class="author-name">{r.name}</div>
              <div class="author-source"><img src="/img/nextdoorlogo_2.webp" alt="NextDoor" /> NextDoor</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="services-section">
    <h2>Our Services</h2>
    <p class="services-subtitle">Professional cleaning for every need</p>
    <div class="services-grid">
      <a href="/services/window-washing" class="service-card">
        <img src="/img/window_washing_image.png" alt="Window Washing" />
        <div class="service-card-body"><h3>Window Washing</h3><p>We ensure your windows are spotless, enhancing the clarity and beauty of your home.</p></div>
      </a>
      <a href="/services/screen-cleaning" class="service-card">
        <img src="/img/cover-slides/slide-4.png" alt="Screen Cleaning" />
        <div class="service-card-body"><h3>Screen Cleaning</h3><p>We remove built-up dust, pollen, dirt, and grime — leaving screens clean and clear.</p></div>
      </a>
      <a href="/services/solar-panel-cleaning" class="service-card">
        <img src="/img/solar_1.png" alt="Solar Panel Cleaning" />
        <div class="service-card-body"><h3>Solar Cleaning</h3><p>We clean solar panels to enhance your home's beauty and efficiency.</p></div>
      </a>
    </div>
  </section>

  <!-- About / Guarantees -->
  <section id="about" class="about-section">
    <div class="about-grid">
      <div class="about-image"><img src="/img/water_pole_2.jpg" alt="Aloha Window Bros at work" /></div>
      <div class="about-content">
        <h2>Our Guarantees</h2>
        <div class="guarantee-item">
          <div class="guarantee-icon">✓</div>
          <div><h4>Your Satisfaction</h4><p>Before we leave, we walk around the property with you to ensure you absolutely love it.</p></div>
        </div>
        <div class="guarantee-item">
          <div class="guarantee-icon">⭐</div>
          <div><h4>High-Quality Service</h4><p>We use top-of-the-line tools including water-fed poles and pressurized screen cleaners.</p></div>
        </div>
        <div class="guarantee-item">
          <div class="guarantee-icon">💬</div>
          <div><h4>Customer Service</h4><p>Punctual arrivals, quick communication, and accommodating any specific requests.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="areas-section">
    <div class="areas-inner">
      <div class="areas-text">
        <h2>Serving Your Neighborhood</h2>
        <p>Locally owned and operated in Ventura County. We know these neighborhoods because we grew up here — Westlake High alumni proudly serving our community.</p>
      </div>
      <div class="areas-grid">
        {[
          { name: 'Thousand Oaks', desc: 'Our home base' },
          { name: 'Westlake Village', desc: 'Full coverage' },
          { name: 'Agoura Hills', desc: 'Full coverage' },
          { name: 'Newbury Park', desc: 'Full coverage' },
          { name: 'Santa Barbara', desc: 'Expanding' },
          { name: 'Ventura County', desc: 'County-wide' },
        ].map((a) => (
          <div class="area-card">
            <span class="area-pin">📍</span>
            <div><strong>{a.name}</strong><span class="area-desc">{a.desc}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="faq-section">
    <h2>Frequently Asked Questions</h2>
    <p class="faq-subtitle">Everything you need to know before booking</p>
    <div class="faq-list">
      {[
        { q: 'How much does window cleaning cost?', a: 'Every home is different! We provide free on-site quotes so you get an accurate price — no surprises. Most residential jobs range from $150–$400 depending on the number of windows.' },
        { q: 'Do I need to be home during the cleaning?', a: "Not necessarily. As long as we can access the windows, we can get the job done. We'll walk through the results with you when you're available." },
        { q: "What's included in the service?", a: 'Our standard service includes windows, screens, frames, and sills — a complete four-in-one clean. We also offer solar panel cleaning and screen repair.' },
        { q: 'Are you insured?', a: "Yes! We're fully insured so you can have complete peace of mind while we work on your property." },
        { q: 'How often should I have my windows cleaned?', a: "We recommend every 3–6 months for most homes. If you're near trees, construction, or the coast, more frequent cleaning keeps things crystal clear." },
        { q: "What if I'm not satisfied with the results?", a: "We walk the property with you before we leave. If anything doesn't look perfect, we redo it on the spot — 100% satisfaction guaranteed." },
      ].map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- Wave: FAQ → CTA -->
  <div class="wave-divider wave-divider-pre-cta">
    <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="wg2" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#1e3a5f"/>
          <stop offset="50%" stop-color="#2563eb"/>
          <stop offset="100%" stop-color="#7c3aed"/>
        </linearGradient>
      </defs>
      <path d="M0,70 C320,20 640,60 960,25 C1120,10 1300,40 1440,20 L1440,70 Z" fill="url(#wg2)"/>
      <path d="M0,70 C400,35 800,65 1200,30 L1440,45 L1440,70 Z" fill="url(#wg2)" opacity="0.3"/>
    </svg>
  </div>

  <!-- CTA Banner -->
  <section class="cta-banner">
    <h2>Ready for Crystal Clear Windows?</h2>
    <p>Schedule your free quote today — we'll drive out to you!</p>
    <a href={CALENDLY} class="cta-btn" target="_blank" rel="noopener noreferrer">Schedule Free Quote</a>
  </section>

  <!-- Wave: CTA → Contact -->
  <div class="wave-divider wave-divider-post-cta" style="background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 50%, #7c3aed 100%);">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 C360,50 720,10 1080,35 C1260,47 1380,25 1440,30 L1440,60 L0,60 Z" fill="#f8fafc"/>
    </svg>
  </div>

  <!-- Contact -->
  <section id="contact" class="contact-section">
    <h2>Contact Us</h2>
    <p class="contact-subtitle">Get in touch for all your window cleaning needs</p>
    <div class="contact-grid">
      <div class="contact-card"><div class="contact-card-icon">📍</div><h4>Location</h4><p>Ventura County & Santa Barbara County, CA</p></div>
      <div class="contact-card"><div class="contact-card-icon">📞</div><h4>Call Us</h4><a href={PHONE_LINK}>{PHONE}</a></div>
      <div class="contact-card"><div class="contact-card-icon">✉️</div><h4>Email Us</h4><a href={`mailto:${EMAIL}`}>{EMAIL}</a></div>
    </div>
  </section>

  <!-- Wave: Contact → Footer -->
  <div class="wave-divider wave-divider-footer">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="wg3" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#1a1a2e"/>
          <stop offset="60%" stop-color="#1e2854"/>
          <stop offset="100%" stop-color="#2d1b69"/>
        </linearGradient>
      </defs>
      <path d="M0,60 C480,15 960,50 1440,10 L1440,60 Z" fill="url(#wg3)"/>
      <path d="M0,60 C320,30 800,55 1440,20 L1440,60 Z" fill="url(#wg3)" opacity="0.5"/>
    </svg>
  </div>

  <Footer slot="footer" />
</Base>
